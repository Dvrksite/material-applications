# Используем стабильный образ
FROM node:16-alpine

# 1. СРАЗУ СОЗДАЕМ ПОЛЬЗОВАТЕЛЯ (до всех остальных действий)
# Создаем системную группу и пользователя с конкретным ID
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# 2. Указываем рабочую директорию
WORKDIR /usr/src/app

# 3. Копируем файлы зависимостей
COPY package*.json ./

# 4. Устанавливаем библиотеки
RUN npm install

# 5. Копируем исходный код
COPY . .

# 6. --- НАСТРОЙКА ПРАВ (ЗАДАНИЕ 3.5) ---
# Передаем права на папку нашему новому пользователю
RUN chown -R appuser:appgroup /usr/src/app

# 7. ПЕРЕКЛЮЧАЕМСЯ НА ПОЛЬЗОВАТЕЛЯ
# Теперь Docker точно найдет его в /etc/passwd внутри образа
USER appuser

# Открываем порт и запускаем приложение
EXPOSE 8080
CMD ["node", "index.js"]